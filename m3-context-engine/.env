# M3 CONTEXT ENGINE CONFIGURATION

# M1 PI ENGINE INTEGRATION
M1_API_URL=http://localhost:5000
M1_API_TOKEN=demo-token-m3-to-m1

# HEARTBEAT CONFIGURATION
HEARTBEAT_INTERVAL=60

# SIMULATION MODE
SIMULATION_MODE=true

# LOGGING CONFIGURATION
LOG_LEVEL=INFO
DEMO_MODE=true

# MEMORY CONFIGURATION
SNAPSHOT_RETENTION_DAYS=7
MEMORY_DIR=./memory

# INTELLIGENCE CONFIGURATION
PATTERN_MIN_REPETITIONS=3
PATTERN_TIME_BUCKET_MINUTES=30
PREDICTION_ADVANCE_MINUTES=15
PREDICTION_MIN_CONFIDENCE=0.5
