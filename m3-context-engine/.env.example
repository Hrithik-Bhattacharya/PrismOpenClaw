# M3 Context Engine Configuration

# Security token to send data to the PI Engine (M1)
M3_API_TOKEN=your-secure-m3-token-here

# API URL for the PI Engine (M1)
M1_API_URL=http://localhost:5000

# ---------------------------------------------------------
# External APIs (Fill these out as you integrate sensors)
# ---------------------------------------------------------

# Google Calendar API (for upcoming events)
GOOGLE_CALENDAR_API_KEY=

# Wearable / Fitness API (for stress, activity)
FITNESS_API_KEY=

# Location / Maps API
MAPS_API_KEY=
