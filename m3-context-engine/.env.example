# ─────────────────────────────────────────────────────────────────
# 🧠 M3 CONTEXT ENGINE CONFIGURATION
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────
# 📡 M1 PI ENGINE INTEGRATION
# M3 pushes context data to M1 every 60 seconds
# ─────────────────────────────────────────────────────────────────
M1_API_URL=http://localhost:5000
M1_API_TOKEN=your-m3-api-token-here

# ─────────────────────────────────────────────────────────────────
# ⏱️  HEARTBEAT CONFIGURATION
# How often M3 updates context (in seconds)
# ─────────────────────────────────────────────────────────────────
HEARTBEAT_INTERVAL=60

# ─────────────────────────────────────────────────────────────────
# 🎭 SIMULATION MODE
# Set to 'true' for demo without real hardware sensors
# Set to 'false' for production with real GPS/WiFi/Calendar
# ─────────────────────────────────────────────────────────────────
SIMULATION_MODE=true

# ─────────────────────────────────────────────────────────────────
# 📊 LOGGING CONFIGURATION
# ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEMO_MODE=true

# ─────────────────────────────────────────────────────────────────
# 💾 MEMORY CONFIGURATION
# ─────────────────────────────────────────────────────────────────
SNAPSHOT_RETENTION_DAYS=7
MEMORY_DIR=./memory

# ─────────────────────────────────────────────────────────────────
# 🧠 INTELLIGENCE CONFIGURATION
# ─────────────────────────────────────────────────────────────────
PATTERN_MIN_REPETITIONS=3
PATTERN_TIME_BUCKET_MINUTES=30
PREDICTION_ADVANCE_MINUTES=15
PREDICTION_MIN_CONFIDENCE=0.5
