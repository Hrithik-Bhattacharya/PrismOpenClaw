# ---------------------------------------------------------
# 🧠 PI ENGINE (M1) CONFIGURATION
# ---------------------------------------------------------

# 🧠 MULTI-LLM PROVIDER CONFIGURATION
# LLM_PROVIDER can be 'groq', 'gemini', or 'auto' (fails over Groq -> Gemini)
LLM_PROVIDER=auto
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here

# Integration API Tokens
M3_API_TOKEN=your-m3-api-token-here
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# Optional M4 live notification push from M1 (safe fallback if unavailable)
ENABLE_M4_PUSH=false
M4_API_URL=http://localhost:8000
M4_API_TIMEOUT_MS=2000

# ---------------------------------------------------------
# 🛡️ FORTIFIED DEMO & TESTING FLAGS (THE "GOD MODE" CONTROLS)
# ---------------------------------------------------------

# 1. Built-in Simulators (Run full system even if M2/M3/M4 are offline)
USE_M3_SIM=true
USE_M2_SIM=true
USE_M4_SIM=true

# 2. Contract Enforcer (Strict Mode)
# If true, it will reject bad M3 context payloads. If false, it auto-fills.
# -> Use TRUE during integration week. Use FALSE on demo day.
STRICT_CONTRACT=false

# 3. Deterministic Demo Switch (No Surprises)
# If true, ignores live inputs and runs a perfectly scripted narrative.
DEMO_LOCK=false
DEMO_SCENE=1

# 4. Replay / Record Mode
# Ultimate safety net: Record a perfect run and replay it later.
RECORD_MODE=false
REPLAY_MODE=false

# ---------------------------------------------------------
# ⚙️ SYSTEM CONFIG
# ---------------------------------------------------------
HEARTBEAT_INTERVAL=10000
MEMORY_ENABLED=true
LLM_MODEL=gpt-4o-mini
DEBUG=true
PORT=5000
