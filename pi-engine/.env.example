# PI Engine Configuration

# OpenAI API Key (optional - engine falls back to rules if not provided)
OPENAI_API_KEY=sk-your-key-here

# Debug Mode
DEBUG=false

# Heartbeat Interval (milliseconds)
HEARTBEAT_INTERVAL=10000

# Memory Management
MEMORY_ENABLED=true
MEMORY_LOG_FILE=memory.log

# LLM Configuration
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=200

# Logging
LOG_LEVEL=info
LOG_FILE=pi-engine.log
