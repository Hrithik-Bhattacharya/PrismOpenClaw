# ============================================
# M2 (ANDROID ADB EXECUTOR) - Environment Template
# ============================================

# ADB target
# - Keep localhost for same-machine ADB server
# - Use device host/IP only if ADB is remote
ADB_HOST=127.0.0.1
ADB_PORT=5037

# M1 API base URL
# M2 uses this for:
# - fetching decision payloads via --url
# - sending execution ACK to: {M1_API_URL}/ack
M1_API_URL=http://localhost:5000

# Retry behavior for failed ADB commands
RETRY_ATTEMPTS=2
RETRY_DELAY=1000

# Safety switch
# true  = ask confirmation for dangerous actions
# false = run dangerous actions without prompt
CONFIRM_DANGEROUS=true
